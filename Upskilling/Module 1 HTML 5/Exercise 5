<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Registration Form</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
        }
        .form-container {
            width: 450px;
            margin: 30px auto;
            padding: 20px;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 0 10px gray;
        }
        h2 {
            text-align: center;
            color: #007BFF;
        }
        label {
            display: block;
            margin-top: 12px;
            font-weight: bold;
        }
        input,
        select,
        textarea {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        textarea {
            resize: vertical;
        }
        button {
            width: 100%;
            margin-top: 15px;
            padding: 10px;
            background-color: #007BFF;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
        button:hover {
            background-color: #0056b3;
        }
        output {
            display: block;
            margin-top: 15px;
            color: green;
            font-weight: bold;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="form-container">
        <h2>Event Registration Form</h2>
        <form onsubmit="showMessage(); return false;">
            <label for="name">Name</label>
            <input type="text" id="name" placeholder="Enter your full name" required autofocus>
            <label for="email">Email</label>
            <input type="email" id="email" placeholder="Enter your email address" required>
            <label for="date">Event Date</label>
            <input type="date" id="date" required>
            <label for="eventType">Event Type</label>
            <select id="eventType" required>
                <option value="">Select an Event</option>
                <option>Sports Day</option>
                <option>Cultural Festival</option>
                <option>Coding Workshop</option>
                <option>Tree Plantation Drive</option>
            </select>
            <label for="message">Message</label>
            <textarea id="message" rows="4"  placeholder="Enter your message..." required></textarea>
            <button type="submit">Register</button>
            <output id="confirmation"></output>
        </form>
    </div>
    <script>
        function showMessage() {
            document.getElementById("confirmation").value ="Registration Successful! Thank you for registering.";
        }
    </script>
</body>
</html>
