<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome Banner</title>
    <style>
        #welcomeBanner {
            background-color: blue;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .highlight {
            background-color: yellow;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div id="welcomeBanner">
        <h1>Welcome, Student!</h1>
        <p>
            You have successfully logged in.
        </p>
        <p class="highlight">
            New events are available now!
        </p>
        <p>
            <span style="color: red; font-weight: bold;">
                Special Offer: Get 50% discount on workshop registration!
            </span>
        </p>
    </div>
</body>
</html>
