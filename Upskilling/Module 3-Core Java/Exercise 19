interface Playable{
    void play();
}
class Guitor implements Playable{
    public void play(){
        System.out.println("guitor is playing");
    }
}
class Piano implements Playable{
    public void play(){
        System.out.println("piano is playing");
    }
}
public class Main
{
	public static void main(String[] args) {
		Guitor gui = new Guitor();
		Piano pia = new Piano();
		gui.play();
		pia.play();
	}
}
