import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	    Scanner sc = new Scanner(System.in);
		System.out.print("Enter the number: ");
		int n = sc.nextInt();
		int r=1;
		if(n==0){
		    System.out.print("1");
		}
		else{
		    for(int i=1;i<=n;i++){
		        r*=i;
		    }
		}
		System.out.print(r);
	}
}
