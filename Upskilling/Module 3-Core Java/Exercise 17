import java.util.Scanner;
class Car{
    String make="TATA";
    String model="Sierra";
    int year=2014;
    void displayDetails(){
        System.out.println("Make: "+make);
        System.out.println("Model: "+model);
        System.out.println("Year: "+year);
    }
}
public class Main
{
	public static void main(String[] args) {
		Car obj = new Car();
		obj.displayDetails();
		
	}
}
