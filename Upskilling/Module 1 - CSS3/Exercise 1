<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSS Types Example</title>
    <link rel="stylesheet" href="styles.css">
    <style>
        body {
            background-color: lightblue;
        }
    </style>
</head>
<body>
    <h1 style="color: red;">Welcome to CSS Styling</h1>
    <h2 class="header">Student Portal</h2>
    <p class="content">
        This page demonstrates Inline, Internal, and External CSS.
    </p>
</body>
</html>


.header {
    color: darkblue;
    text-align: center;
    font-size: 30px;
}
.content {
    font-size: 18px;
    color: black;
    padding: 10px;
}
