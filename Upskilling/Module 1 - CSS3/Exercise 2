body {
    background-color: #f4f4f4;
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
}
header {
    background-color: #333;
    color: white;
    text-align: center;
    padding: 20px;
}
nav {
    background-color: #007BFF;
    padding: 10px;
}
nav a {
    color: white;
    text-decoration: none;
    margin-right: 15px;
}
main {
    padding: 20px;
}
.highlight {
    background-color: yellow;
    font-weight: bold;
}
.cta-button {
    background-color: #007BFF;
    color: white;
    padding: 12px 20px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}
footer {
    background-color: #222;
    color: white;
    text-align: center;
    padding: 10px;
}
