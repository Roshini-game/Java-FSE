styles.css


* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}
h2 {
    color: darkblue;
    margin-bottom: 10px;
}
#mainHeader {
    background-color: #007BFF;
    color: white;
    text-align: center;
    padding: 20px;
}
.eventCard {
    background-color: #f4f4f4;
    border: 1px solid #ccc;
    margin: 20px;
    padding: 15px;
    border-radius: 8px;
}
h3, p {
    color: #333;
    font-family: Arial, sans-serif;
}
